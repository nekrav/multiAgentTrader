POSTGRES_DB=aitraders
POSTGRES_USER=aitraders
POSTGRES_PASSWORD=replace_with_a_long_random_password

PORT=4000
DATABASE_URL=postgres://aitraders:replace_with_a_long_random_password@postgres:5432/aitraders
REDIS_URL=redis://redis:6379

# Use :80 for public-IP HTTP testing.
# Use your-domain.example when DNS points at the EC2 instance; Caddy will request HTTPS certs.
SITE_ADDRESS=:80

# Browser calls the API through Caddy. Caddy strips /api before forwarding to Nest.
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://api:4000

# For a domain, set this to https://your-domain.example.
# For first EC2 public-IP testing, * is acceptable for the scaffold.
CORS_ORIGIN=*

AGENT_ENDPOINTS_JSON={"market-data":"http://market-data-agent:7001","strategy-research":"http://strategy-research-agent:7002","risk":"http://risk-agent:7003","execution":"http://execution-agent:7004","post-trade-review":"http://post-trade-review-agent:7005"}
