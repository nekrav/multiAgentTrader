POSTGRES_DB=aitraders
POSTGRES_USER=aitraders
POSTGRES_PASSWORD=change_me_before_deploy

PORT=4000
DATABASE_URL=postgres://aitraders:change_me_before_deploy@postgres:5432/aitraders
REDIS_URL=redis://redis:6379

# Local direct dev:
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://api:4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change_me_to_a_long_random_secret
SIGNUP_CREDITS=50
ADMIN_EMAILS=
RUN_TIMEOUT_MS=120000
RUNS_CONCURRENCY=4

# EC2/proxy deploy:
# SITE_ADDRESS=:80
# NEXT_PUBLIC_API_URL=/api
# CORS_ORIGIN=https://your-domain.example,http://your-ec2-public-ip

AGENT_ENDPOINTS_JSON={"market-data":"http://market-data-agent:7001","strategy-research":"http://strategy-research-agent:7002","risk":"http://risk-agent:7003","execution":"http://execution-agent:7004","post-trade-review":"http://post-trade-review-agent:7005"}
